{
  "manifest_version": 3,
  "name": "XRPL Dev Wallet",
  "version": "1.0.0",
  "description": "XRPL wallet with WalletConnect support — sign, submit, and monitor transactions",
  "permissions": ["storage", "notifications", "clipboardWrite"],
  "host_permissions": [
    "wss://s.devnet.rippletest.net/*",
    "wss://s.altnet.rippletest.net/*",
    "wss://testnet.xrpl-labs.com/*",
    "wss://s1.ripple.com/*",
    "wss://s2.ripple.com/*",
    "wss://xrplcluster.com/*",
    "https://faucet.devnet.rippletest.net/*",
    "https://faucet.altnet.rippletest.net/*",
    "https://*.walletconnect.com/*",
    "wss://*.walletconnect.com/*",
    "https://*.walletconnect.org/*",
    "wss://*.walletconnect.org/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
